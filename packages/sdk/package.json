{
  "name": "@ponderdb/sdk",
  "version": "0.2.2",
  "description": "PonderDB TypeScript SDK — programmatic access to PonderDB",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ponderdb/core": "0.2.2"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ponderdb/ponderdb.git",
    "directory": "packages/sdk"
  }
}
