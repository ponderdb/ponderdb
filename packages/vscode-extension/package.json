{
  "name": "ponderdb",
  "displayName": "PonderDB",
  "description": "AI memory management — search, store, and recall project knowledge from VS Code",
  "version": "0.3.1",
  "publisher": "ponderdb",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["ai", "memory", "mcp", "knowledge", "context"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ponderdb",
          "title": "PonderDB",
          "icon": "media/ponderdb-sidebar.svg"
        }
      ]
    },
    "views": {
      "ponderdb": [
        {
          "id": "ponderdb.status",
          "name": "Connection",
          "type": "webview"
        },
        {
          "id": "ponderdb.search",
          "name": "Search",
          "type": "webview"
        },
        {
          "id": "ponderdb.memories",
          "name": "Memories"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "ponderdb.memories",
        "contents": "No memories found.\n\nMake sure PonderDB server is running and API key is configured.\n\n[Configure Settings](command:workbench.action.openSettings?%5B%22ponderdb%22%5D)\n\n[Refresh](command:ponderdb.refresh)"
      }
    ],
    "commands": [
      {
        "command": "ponderdb.remember",
        "title": "PonderDB: Remember Selection",
        "icon": "$(save)"
      },
      {
        "command": "ponderdb.search",
        "title": "PonderDB: Search Memories",
        "icon": "$(search)"
      },
      {
        "command": "ponderdb.list",
        "title": "PonderDB: List Memories"
      },
      {
        "command": "ponderdb.importFile",
        "title": "PonderDB: Import Current File",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "ponderdb.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ponderdb.viewMemory",
        "title": "View Memory",
        "icon": "$(eye)"
      },
      {
        "command": "ponderdb.deleteMemory",
        "title": "Delete Memory",
        "icon": "$(trash)"
      },
      {
        "command": "ponderdb.copyContent",
        "title": "Copy Content",
        "icon": "$(clippy)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ponderdb.remember",
          "group": "ponderdb",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "ponderdb.refresh",
          "when": "view == ponderdb.memories",
          "group": "navigation"
        },
        {
          "command": "ponderdb.importFile",
          "when": "view == ponderdb.memories",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ponderdb.viewMemory",
          "when": "view == ponderdb.memories && viewItem == memory",
          "group": "inline@1"
        },
        {
          "command": "ponderdb.copyContent",
          "when": "view == ponderdb.memories && viewItem == memory",
          "group": "inline@2"
        },
        {
          "command": "ponderdb.deleteMemory",
          "when": "view == ponderdb.memories && viewItem == memory",
          "group": "inline@3"
        }
      ]
    },
    "configuration": {
      "title": "PonderDB",
      "properties": {
        "ponderdb.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:7437",
          "description": "PonderDB server URL"
        },
        "ponderdb.apiKey": {
          "type": "string",
          "default": "",
          "description": "PonderDB API key (pndr_...)"
        },
        "ponderdb.projectId": {
          "type": "string",
          "default": "",
          "description": "Default project ID"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ponderdb/ponderdb.git",
    "directory": "packages/vscode-extension"
  },
  "license": "MIT"
}
