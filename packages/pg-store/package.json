{
  "name": "@ponderdb/pg-store",
  "version": "0.2.1",
  "description": "PonderDB PostgreSQL + pgvector storage adapter for cloud mode",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ponderdb/core": "0.2.1",
    "pg": "^8.16.0",
    "pgvector": "^0.2.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.0"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ponderdb/ponderdb.git",
    "directory": "packages/pg-store"
  }
}
