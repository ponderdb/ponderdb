{
  "name": "@ponderdb/core",
  "version": "0.2.2",
  "description": "PonderDB core memory engine — types, interfaces, storage and search abstractions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
