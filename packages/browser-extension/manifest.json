{
  "manifest_version": 3,
  "name": "PonderDB",
  "description": "Save web content as AI memories to PonderDB",
  "version": "0.2.1",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": []
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
