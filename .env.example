# ─────────────────────────────────────────────
# PonderDB Configuration
# ─────────────────────────────────────────────

# Server port (default: 7437)
PONDER_PORT=7437

# Server host — use 0.0.0.0 to expose to network (default: 127.0.0.1)
PONDER_HOST=127.0.0.1

# Data directory — SQLite DB, model cache stored here (default: ~/.ponderdb)
PONDER_DATA_DIR=~/.ponderdb

# PostgreSQL connection (set to use cloud mode instead of SQLite)
# When set, PonderDB uses PostgreSQL + pgvector instead of SQLite + sqlite-vec
# DATABASE_URL=postgresql://user:pass@localhost:5432/ponderdb

# Require API key for REST API access (default: true)
# Set to false to disable auth (not recommended for shared/network access)
PONDER_API_KEY_REQUIRED=true

# ─────────────────────────────────────────────
# Embeddings
# ─────────────────────────────────────────────

# Embedding provider (default: transformer)
#   transformer — all-MiniLM-L6-v2 via Transformers.js (384d, ~33MB download, local)
#   openai      — OpenAI text-embedding-3-small (1536d, requires API key)
#   local       — hash-based placeholder (no download, no semantics, fast startup)
# PONDER_EMBEDDER=transformer

# OpenAI API key (required when PONDER_EMBEDDER=openai)
# OPENAI_API_KEY=sk-xxx

# OpenAI embedding model (default: text-embedding-3-small)
# PONDER_EMBEDDING_MODEL=text-embedding-3-small

# Embedding dimensions — must match model (default: 1536 for openai, 384 for transformer)
# PONDER_EMBEDDING_DIMS=1536

# ─────────────────────────────────────────────
# API Key
# ─────────────────────────────────────────────

# Default project ID for MCP tools (optional — scopes memories to a project)
# PONDER_PROJECT_ID=my-project

# ─────────────────────────────────────────────
# OAuth (optional — enables Google/GitHub login on dashboard)
# ─────────────────────────────────────────────

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_CALLBACK_URL=http://127.0.0.1:7437/auth/google/callback

# GitHub OAuth (https://github.com/settings/developers)
# GITHUB_CLIENT_ID=xxx
# GITHUB_CLIENT_SECRET=xxx
GITHUB_CALLBACK_URL=http://127.0.0.1:7437/auth/github/callback

# JWT secret for session tokens (auto-generated for dev, set in production)
# PONDER_JWT_SECRET=your-secret-here

# Base URL for OAuth callbacks (default: http://127.0.0.1:7437)
# PONDER_BASE_URL=https://your-domain.com
