# ─────────────────────────────────────────────
# PonderDB Configuration
# ─────────────────────────────────────────────

# Server port (default: 7437)
PONDER_PORT=7437

# Server host — use 0.0.0.0 to expose to network (default: 127.0.0.1)
PONDER_HOST=127.0.0.1

# Data directory — SQLite DB, model cache stored here (default: ~/.ponderdb)
PONDER_DATA_DIR=~/.ponderdb

# Require API key for REST API access (default: true)
# Set to false to disable auth (not recommended for shared/network access)
PONDER_API_KEY_REQUIRED=true

# ─────────────────────────────────────────────
# Embeddings
# ─────────────────────────────────────────────

# Embedding provider (default: transformer)
#   transformer — real semantic embeddings via all-MiniLM-L6-v2 (~33MB model download on first start)
#   local       — hash-based placeholder (no download, no real semantics, fast startup)
# PONDER_EMBEDDER=transformer

# OpenAI API key (optional — for future OpenAI embedding support)
# OPENAI_API_KEY=sk-xxx

# ─────────────────────────────────────────────
# API Key
# ─────────────────────────────────────────────

# Pre-set API key for CLI/SDK usage (auto-generated on first server start)
# PONDER_API_KEY=pndr_xxx
