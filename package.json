{
  "name": "ponderdb",
  "private": true,
  "version": "0.0.0",
  "description": "Universal AI Agent Memory Server",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=@ponderdb/server",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ponderdb/ponderdb.git"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
